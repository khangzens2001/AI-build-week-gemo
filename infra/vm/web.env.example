# Event Copilot — VM server env (Podman stack). Copy to
# /srv/event-copilot/shared/web.env on the VM, fill REAL values, chmod 600.
# NEVER commit the filled file. Consumed by the `web` container (EnvironmentFile)
# and the reminder timer (CRON_SECRET).

# --- Auth.js / Google OAuth (login is in-scope) ---
AUTH_SECRET=                                   # openssl rand -base64 32
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_URL=https://aabw.devlab.vn
# REQUIRED behind nginx on a VM (no Vercel host auto-detect), else auth() 500s.
AUTH_TRUST_HOST=true

# --- Gemini ---
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_CHAT_MODEL=gemini-3-flash-preview
GEMINI_EMBED_MODEL=gemini-embedding-001
# MUST match the value used when embedding into Chroma (immutable per collection).
GEMINI_EMBED_DIM=3072

# --- Chroma (the `chroma` container on ecnet; NO CHROMA_API_KEY = local client) ---
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=aabw

# --- D1 via the bun:sqlite shim container on ecnet (NO Cloudflare creds needed) ---
D1_LOCAL_URL=http://d1shim:8787/query

# --- Cron / reminders ---
CRON_SECRET=                                   # openssl rand -hex 32

# --- Auto-crawl → re-ingest (the crawl-ingest one-shot reads these) ---
# FIRECRAWL_API_KEY drives the Python crawler (craw_data1). INGEST_HOOK_TOKEN
# guards POST /api/ingest/hook — the crawl-ingest script sends it as a Bearer
# after re-embedding so a content change fans out as a Cue Pulse + push.
FIRECRAWL_API_KEY=                             # fc-...
INGEST_HOOK_TOKEN=                             # openssl rand -hex 32 (must match what the app expects)

# --- Push notifications: Firebase Cloud Messaging (replaces web-push/VAPID) ---
# Client web-app config + the Web Push certificate public key (Cloud Messaging tab).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
# Server: base64 of the service-account JSON (avoids multi-line private_key issues):
#   base64 -i service-account.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_B64=

# --- Web Push / VAPID (DEPRECATED — superseded by FCM above; unused) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- Demo clock (optional; freeze "now" mid event so the UI is alive) ---
DEMO_NOW=
NEXT_PUBLIC_DEMO_NOW=
