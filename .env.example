# =============================================================================
# Cue — Environment Variables
# =============================================================================
# Copy this file to `.env.local` (Next.js app) and/or `.env` (scripts), then
# fill in real values. NEVER commit the filled file. On Vercel, set these in
# Project Settings → Environment Variables. On Cloudflare, use `wrangler secret`
# or workers/data-api/.dev.vars for local Worker dev.
#
# Legend:  [REQUIRED] must be set for the app to run (no mock fallback).
#          [PROD]     needed for production / deploy.
#          [OPTIONAL] feature flag or stretch feature.
# =============================================================================

# -----------------------------------------------------------------------------
# Auth.js / NextAuth v5 + Google Login  (Next.js / Vercel)
# -----------------------------------------------------------------------------
# Generate AUTH_SECRET with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=                                   # [REQUIRED]
# Google OAuth client (console.cloud.google.com → Credentials → OAuth client ID,
# type "Web application"). Authorized redirect URIs MUST include:
#   http://localhost:3000/api/auth/callback/google      (local dev)
#   https://<your-vercel-domain>/api/auth/callback/google  (production)
AUTH_GOOGLE_ID=                                # [REQUIRED] auto-detected by Google provider
AUTH_GOOGLE_SECRET=                            # [REQUIRED]
# AUTH_URL: only needed locally / on non-Vercel hosts. Vercel auto-infers it.
AUTH_URL=http://localhost:3000                 # [OPTIONAL local]

# -----------------------------------------------------------------------------
# Gemini 3  (read automatically by @ai-sdk/google)
# -----------------------------------------------------------------------------
GOOGLE_GENERATIVE_AI_API_KEY=                  # [REQUIRED] from ai.google.dev
# Chat model id (PREVIEW naming — confirm current id at ai.google.dev/gemini-api/docs/gemini-3).
#   snappy:  gemini-3-flash-preview     accurate: gemini-3-pro-preview
GEMINI_CHAT_MODEL=gemini-3-flash-preview       # [REQUIRED]
# Embedding model + dimension. Dimension is IMMUTABLE once Chroma collection is
# created — do NOT change after first seed. 3072 is the gemini-embedding-001 default.
GEMINI_EMBED_MODEL=gemini-embedding-001        # [REQUIRED]
GEMINI_EMBED_DIM=3072                          # [REQUIRED] must match seed + query

# -----------------------------------------------------------------------------
# Firecrawl  (ingest / Devpost scraper / schedule monitor)
# -----------------------------------------------------------------------------
FIRECRAWL_API_KEY=                             # [REQUIRED for ingest] fc-...

# -----------------------------------------------------------------------------
# MiMo (Xiaomi) — OFFLINE seed/ingest label classifier (OpenAI-compatible).
#   Used only by the seed/ingest pipeline, never on a request hot path. Degrades
#   gracefully: unset MIMO_API_KEY or CLASSIFY!=1 → deterministic heuristic only.
#   NOTE: a `tp-` token is AUP-restricted to coding tools — rotate it after the demo.
# -----------------------------------------------------------------------------
MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1   # [OPTIONAL] defaults to this
MIMO_MODEL=mimo-v2.5                           # [OPTIONAL] defaults to "mimo-v2.5"
MIMO_API_KEY=                                  # [OPTIONAL] Bearer token; required only when CLASSIFY=1
CLASSIFY=                                       # [OPTIONAL] set to "1" to opt-in to MiMo classification (off = deterministic)

# -----------------------------------------------------------------------------
# Chroma (vector DB)
#   Local dev  → Chroma server via Podman (CHROMA_HOST/PORT used).
#   Production → Chroma Cloud (set CHROMA_API_KEY/TENANT/DATABASE; host/port ignored).
# The client picks Cloud when CHROMA_API_KEY is set, else local host:port.
# -----------------------------------------------------------------------------
CHROMA_HOST=localhost                          # [REQUIRED local]
CHROMA_PORT=8000                               # [REQUIRED local]
CHROMA_COLLECTION=aabw                         # [OPTIONAL] defaults to "aabw"
CHROMA_API_KEY=                                # [PROD] Chroma Cloud
CHROMA_TENANT=                                 # [PROD] Chroma Cloud
CHROMA_DATABASE=aabw                           # [PROD] Chroma Cloud

# -----------------------------------------------------------------------------
# Cloudflare D1  (Option B — all-Vercel, REST)
#   - Runtime reads from Vercel use CLOUDFLARE_API_TOKEN + ACCOUNT_ID + D1_DATABASE_ID.
#   - drizzle-kit (d1-http) migrations use the same trio (token needs D1 edit).
#   Create DB:  wrangler d1 create aabw   → copy the database_id below.
#   API token:  Cloudflare dashboard → My Profile → API Tokens (D1 Edit).
# -----------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=                         # [REQUIRED]
CLOUDFLARE_API_TOKEN=                          # [REQUIRED] D1 edit permission
D1_DATABASE_ID=                                # [REQUIRED] from `wrangler d1 create aabw`

# -----------------------------------------------------------------------------
# Demo clock  (CRITICAL for demo)
#   The event runs Jul 8–12 2026, but you may demo earlier. Set DEMO_NOW to an
#   ISO timestamp to make "now / next" resolve against event time instead of the
#   real wall clock. Leave blank in production during the live event.
#   Example: a time during Day 1 morning.
# -----------------------------------------------------------------------------
DEMO_NOW=2026-07-08T10:30:00+07:00             # [OPTIONAL] blank = real time
NEXT_PUBLIC_DEMO_NOW=2026-07-08T10:30:00+07:00 # [OPTIONAL] client countdown; mirror of DEMO_NOW

# -----------------------------------------------------------------------------
# Push notifications — Firebase Cloud Messaging (FCM)
#   The app sends web push via FCM (replaces the old web-push/VAPID path below).
#   Client config: Firebase console → Project settings → General → your web app.
#   VAPID key:     Firebase console → Cloud Messaging → Web Push certificates
#                  → "Generate key pair" → the public key string.
#   Server creds:  Firebase console → Project settings → Service accounts →
#                  "Generate new private key" → base64 the whole JSON file:
#                    base64 -i service-account.json | tr -d '\n'
#                  (one var avoids the multi-line private_key \n footgun).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=                  # [push] web app config
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=              # [push] <project>.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=               # [push]
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=      # [push]
NEXT_PUBLIC_FIREBASE_APP_ID=                   # [push]
NEXT_PUBLIC_FIREBASE_VAPID_KEY=                # [push] Web Push certificate public key
FIREBASE_SERVICE_ACCOUNT_B64=                  # [push] base64 of the service-account JSON (server only)

# -----------------------------------------------------------------------------
# Web Push (VAPID)  — DEPRECATED, replaced by FCM above.
#   No longer used by any route (kept one release for rollback only). Safe to omit.
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=                              # [DEPRECATED] superseded by FCM
VAPID_PRIVATE_KEY=                             # [DEPRECATED] superseded by FCM
VAPID_SUBJECT=mailto:you@example.com           # [DEPRECATED] superseded by FCM
NEXT_PUBLIC_VAPID_PUBLIC_KEY=                  # [DEPRECATED] superseded by FCM

# -----------------------------------------------------------------------------
# Firecrawl monitor → re-ingest webhook  (Phase 7, optional)
#   Shared secret so the monitor/cron can trigger a re-ingest endpoint.
# -----------------------------------------------------------------------------
INGEST_HOOK_TOKEN=                             # [OPTIONAL feature]

# -----------------------------------------------------------------------------
# Vercel Cron — reminder sweep  (Phase 7)
#   Protects /api/cron/reminders. Vercel Cron sends this as a Bearer token.
#   Generate any long random string: openssl rand -hex 32
# -----------------------------------------------------------------------------
CRON_SECRET=                                   # [OPTIONAL feature]

# -----------------------------------------------------------------------------
# Dev "mock account" sign-in  (NEW — testing authed flows without Google OAuth)
#   In non-production, a Credentials provider ("Continue as Demo Builder") is
#   available so you can test reminders/checklist/teams/mentors without setting
#   up Google OAuth. It is NEVER present in production builds.
#   Set CUE_DEV_AUTH=0 to disable it even in dev. The seeded mock user is
#   builder@cue.dev (id "mock-builder"), loaded by `bun run db:reset:local`.
# -----------------------------------------------------------------------------
CUE_DEV_AUTH=1                                 # [OPTIONAL dev] 0 to disable mock sign-in
NEXT_PUBLIC_CUE_DEV_AUTH=1                      # [OPTIONAL dev] client mirror — hides the Demo button when 0

# -----------------------------------------------------------------------------
# Feature notes (no extra keys needed):
#   • Cue Pulse live feed: POST /api/announcements is guarded by INGEST_HOOK_TOKEN
#     (above). The Firecrawl monitor → /api/ingest/hook path also uses it.
#   • Pitch Coach (/api/pitch/review) and Cue Chat need GOOGLE_GENERATIVE_AI_API_KEY;
#     without it those routes return 503 with a clear message (they never fabricate).
#   • Checklist, Mentors/Office-hours, Teams/Build-log, and the Nudge card are
#     fully functional locally with just the dev sign-in + local D1 (no cloud keys).
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Local D1 shim — point the app at the bun:sqlite dev server (Option B local).
#   Start it with `bun run d1:local`; reset/seed with `bun run db:reset:local`.
# -----------------------------------------------------------------------------
D1_LOCAL_URL=http://localhost:8787/query       # [REQUIRED local dev] omit in prod (uses Cloudflare REST)

# -----------------------------------------------------------------------------
# Option A (deferred) — Worker Data API. Not required for Option B MVP.
# -----------------------------------------------------------------------------
# DATA_API_URL=https://data-api.<you>.workers.dev   # [OPTIONAL future]
# DATA_API_TOKEN=                                    # [OPTIONAL future]
