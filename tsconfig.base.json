{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "declaration": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@event/core": ["./packages/core/src/index.ts"],
      "@event/core/*": ["./packages/core/src/*"],
      "@event/ingest": ["./packages/ingest/src/index.ts"],
      "@event/ingest/*": ["./packages/ingest/src/*"]
    }
  }
}
